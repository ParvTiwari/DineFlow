<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans&display=swap" rel="stylesheet">
    <title>Order Confirmed - DineFlow</title>
    <style>
        body { margin: 0; font-family: 'Josefin Sans', sans-serif; background: #fff; color: #262626; }
        .success-main { min-height: 80vh; display: flex; flex-direction: column;
                        align-items: center; justify-content: center; text-align: center; padding: 24px; }
        .check { width: 84px; height: 84px; border-radius: 50%; background: #2ecc71; color: #fff;
                 display: flex; align-items: center; justify-content: center; font-size: 44px; margin-bottom: 20px; }
        .success-main h1 { margin: 0 0 8px; }
        .success-main p { color: #737373; margin: 4px 0; }
        .order-meta { margin: 16px 0; font-size: 18px; }
        .home-btn { display: inline-block; margin-top: 24px; background: #ff9900; color: #fff;
                    padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: 600; }
        .home-btn:hover { background: #e88a00; }
    </style>
</head>
<body>
    <%- include("includes/navBar.ejs") %>

    <main class="success-main">
        <div class="check">&#10003;</div>
        <h1>Order Confirmed!</h1>
        <p>Thank you<%= user && user.name ? ", " + user.name : "" %>. Your order has been placed.</p>
        <div class="order-meta">
            <p>Order ID: <strong>#<%= orderId %></strong></p>
            <p>Amount Paid: <strong>₹<%= total %></strong></p>
        </div>
        <a class="home-btn" href="/menu">Continue Ordering</a>
    </main>

    <%- include("includes/footer.ejs") %>
</body>
</html>
